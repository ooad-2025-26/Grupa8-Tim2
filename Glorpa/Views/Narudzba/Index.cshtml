@model IEnumerable<Glorpa.Models.Narudzba>
<h1>Narudzbe</h1>
<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Datum</th>
            <th>Status</th>
            <th>UkupnaCijena</th>
            <th>NacinPlacanja</th>
            <th>Korisnik</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Datum</td>
                <td>@item.Status</td>
                <td>@item.UkupnaCijena</td>
                <td>@item.NacinPlacanja</td>
                <td>@item.Korisnik?.Ime</td>
                <td>
                    
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>