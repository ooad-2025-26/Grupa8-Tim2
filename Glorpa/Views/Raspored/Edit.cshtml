@model Glorpa.Models.Raspored

<h1>Edit Raspored</h1>

<form asp-action="Edit">

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Sedmica"></label>
        <input asp-for="Sedmica" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="KorisnikId"></label>

        <select asp-for="KorisnikId"
                asp-items="ViewBag.KorisnikId"
                class="form-control">
        </select>
    </div>

    <br />

    <button type="submit" class="btn btn-primary">
        Save
    </button>

</form>