@model Glorpa.Models.VremenskiUslovi

<h1>Create VremenskiUslovi</h1>

<form asp-action="Create">

    <div class="form-group">
        <label asp-for="Tip"></label>
        <input asp-for="Tip" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Opis"></label>
        <input asp-for="Opis" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="JeLiUslov"></label>
        <input asp-for="JeLiUslov" class="form-check-input" />
    </div>

    <br />

    <button type="submit" class="btn btn-primary">
        Save
    </button>

</form>